# ─────────────────────────────────────────────────────────────────────────────
# ChainPulse AI — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Solana ────────────────────────────────────────────────────────────────────
# Use devnet for development and testing
SOLANA_RPC_URL=https://api.devnet.solana.com

# Demo signer wallet (devnet only — NEVER use a mainnet wallet here)
# Generate with: solana-keygen new --outfile demo-wallet.json
# Then: cat demo-wallet.json | python3 -c "import sys,json,base58; k=json.load(sys.stdin); print(base58.b58encode(bytes(k)).decode())"
DEMO_SIGNER_PRIVATE_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for MVP (justified: hackathon scope, zero infra needed)
DB_URL=file:./dev.db

# For production PostgreSQL:
# DB_URL=postgresql://user:pass@localhost:5432/chainpulse

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# ── AI Provider ───────────────────────────────────────────────────────────────
# Supported: anthropic | openai
AI_PROVIDER=anthropic

# Your API key for the chosen provider
AI_API_KEY=

# Model to use (anthropic: claude-sonnet-4-20250514 | openai: gpt-4o)
AI_MODEL=claude-sonnet-4-20250514

# ── Jupiter ───────────────────────────────────────────────────────────────────
JUPITER_BASE_URL=https://quote-api.jup.ag/v6

# Default input mint (SOL native mint)
JUPITER_INPUT_MINT=So11111111111111111111111111111111111111112

# Default output mint (USDC on devnet)
JUPITER_OUTPUT_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Default slippage in basis points (300 = 3%)
DEFAULT_SLIPPAGE_BPS=300

# ── Agent Loop ────────────────────────────────────────────────────────────────
# Default loop interval in minutes (overridden by token gate)
DEFAULT_LOOP_INTERVAL=15

# ── Token Gate (DeAura) ───────────────────────────────────────────────────────
# Set to "true" to use mock mode (no real on-chain check) — recommended for MVP
TOKEN_GATE_MOCK=true

# DeAura token mint address (replace with real address post-launch)
DEAURA_MINT_ADDRESS=PLACEHOLDER_DEAURA_MINT

# DeAura token thresholds
DEAURA_PREMIUM_THRESHOLD=100
DEAURA_EXECUTION_THRESHOLD=500

# Public link to DeAura token on Jupiter / DEX
DEAURA_TOKEN_LINK=[DEAURA_TOKEN_LINK]

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_DEAURA_TOKEN_LINK=[DEAURA_TOKEN_LINK]

# ── API Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Demo ──────────────────────────────────────────────────────────────────────
# Public devnet wallet to use for demo mode seed data
DEMO_WALLET_ADDRESS=DemoWa11etAddressForChainPulseAIHackathon1

# ── Worker ────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:4000
WORKER_SECRET=dev-worker-secret
